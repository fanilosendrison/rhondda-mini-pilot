# <type>(<scope>): <subject>    # max 70 chars — imperative, no period
#
# <body>                        # explain WHY, not what — wrap at 72 chars
#
# <footer>                      # BREAKING CHANGE: ..., Refs: #123, Closes: #456
#
# ─── Conventional Commits ─────────────────────────────────────────────
# type: feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert
# scope: optional — area affected (e.g. collection, dataset, harness, env, config)
# Breaking change: add "!" after type/scope OR "BREAKING CHANGE:" in footer
#
# Examples:
#   feat(collection): collect 30-draw pool for GSM8K items
#   fix(dataset): handle malformed GSM8K answer field
#   chore: initial commit
