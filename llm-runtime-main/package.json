{
  "name": "@vegacorp/llm-runtime",
  "version": "0.1.0",
  "description": "Runtime TypeScript pour orchestration de providers LLM (completion + embedding) — moteur unique normalisé pour Anthropic, OpenAI, OpenAI-compatible, Google Gemini.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check --no-errors-on-unmatched src tests",
    "lint:fix": "biome check --no-errors-on-unmatched --write src tests",
    "format": "biome format --no-errors-on-unmatched --write src tests",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "ai-json-safe-parse": "^0.3.0",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "keywords": [
    "llm",
    "anthropic",
    "openai",
    "gemini",
    "completion",
    "embedding",
    "runtime"
  ],
  "license": "UNLICENSED",
  "private": true
}
