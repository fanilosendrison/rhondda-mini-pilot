{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "llm_embedding_start",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "callId",
    "provider",
    "model",
    "timestamp",
    "endpoint",
    "textsCount",
    "batchSize"
  ],
  "properties": {
    "eventType": { "const": "llm_embedding_start" },
    "callId": { "type": "string", "minLength": 26, "maxLength": 26 },
    "provider": {
      "enum": [
        "anthropic",
        "openai",
        "google",
        "deepseek",
        "mistral",
        "groq",
        "together",
        "ollama"
      ]
    },
    "model": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "endpoint": { "type": "string" },
    "textsCount": { "type": "integer", "minimum": 0 },
    "batchSize": { "type": "integer", "minimum": 0 }
  }
}
