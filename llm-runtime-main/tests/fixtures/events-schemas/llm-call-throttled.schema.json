{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "llm_call_throttled",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "callId",
    "provider",
    "model",
    "timestamp",
    "waitMs",
    "reason",
    "snapshotState",
    "estimatedTokens"
  ],
  "properties": {
    "eventType": { "const": "llm_call_throttled" },
    "callId": { "type": "string", "minLength": 26, "maxLength": 26 },
    "provider": {
      "enum": [
        "anthropic",
        "openai",
        "google",
        "deepseek",
        "mistral",
        "groq",
        "together",
        "ollama"
      ]
    },
    "model": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "waitMs": { "type": "integer", "minimum": 0 },
    "reason": { "type": "string" },
    "snapshotState": { "enum": ["known", "unknown", "partial"] },
    "estimatedTokens": { "type": "integer", "minimum": 0 }
  }
}
