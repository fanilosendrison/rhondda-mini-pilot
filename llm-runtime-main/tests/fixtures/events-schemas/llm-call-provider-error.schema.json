{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "llm_call_provider_error",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "callId",
    "provider",
    "model",
    "timestamp",
    "status",
    "semanticErrorKind",
    "retryable"
  ],
  "properties": {
    "eventType": { "const": "llm_call_provider_error" },
    "callId": { "type": "string", "minLength": 26, "maxLength": 26 },
    "provider": {
      "enum": [
        "anthropic",
        "openai",
        "google",
        "deepseek",
        "mistral",
        "groq",
        "together",
        "ollama"
      ]
    },
    "model": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "type": "integer" },
    "semanticErrorKind": { "type": "string" },
    "retryable": { "type": "boolean" }
  }
}
