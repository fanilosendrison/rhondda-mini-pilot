# =============================================================================
# .gitignore — Base template
# Covers universally ignored files. Add language/framework-specific entries below.
# Generator: https://www.toptal.com/developers/gitignore
# =============================================================================

# ---------- Environment & Secrets ----------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# ---------- Dependencies ----------
node_modules/
venv/
.venv/
vendor/
.bundle/

# ---------- Build Artifacts ----------
dist/
build/
out/
target/
*.pyc
__pycache__/
*.class
*.o
*.so
*.dll

# ---------- IDE & Editor ----------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- Logs & Temp ----------
*.log
logs/
tmp/
temp/
*.tmp

# ---------- Coverage & Testing ----------
coverage/
.nyc_output/
htmlcov/
.coverage
*.gcov

# ---------- Stack-specific: TypeScript / Node / pnpm ----------
*.tsbuildinfo
.pnpm-store/
.pnp.*
.turbo/
.cache/
.eslintcache

# ---------- Claude Code workflow artifacts (generated, not versioned) ----------
STACK_EVAL.yaml
LIBS_EVAL.yaml
PROJECT_INDEX.md
SPEC_MANIFEST.md
CLAUDE.md
.index-state.json
.claude/run/

# ---------- Claude Code local state (nightly-clean uses GHA, clones dotclaude at runtime) ----------
.claude/
