# Rhondda mini-pilot — environment variables
# Copy to .env (gitignored) and fill in. Loaded via `node --env-file=.env`.

# OpenAI API key with access to the gpt-5.4-mini model (required).
OPENAI_API_KEY=

# Optional knobs. Defaults match the Rhondda mini-pilot request.
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TEMPERATURE=0.7
# GSM8K_ITEM_COUNT=200
# GSM8K_DRAWS_PER_ITEM=30
# GSM8K_POOL_FILE=gsm8k_pool.jsonl
# GSM8K_DATASET_CACHE_FILE=gsm8k_test_cache.jsonl

# Cost estimate defaults use OpenAI standard pricing for gpt-5.4-mini
# as of 2026-06-16: $0.75 input / $4.50 output per 1M tokens.
# OPENAI_INPUT_USD_PER_1M=0.75
# OPENAI_OUTPUT_USD_PER_1M=4.50
